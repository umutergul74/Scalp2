# ═══════════════════════════════════════════════════
# Scalp2 Live Bot — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY:
#   - NEVER commit .env to git
#   - Set IP whitelist on Binance API
#   - Use futures-only, no-withdraw permissions
# ═══════════════════════════════════════════════════

# Binance USDM Futures API (required for live trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Telegram Notifications (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading Mode: true=paper, false=live with real money
PAPER_TRADE=true
